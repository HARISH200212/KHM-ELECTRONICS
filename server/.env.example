# MongoDB connection string (MongoDB Atlas recommended for production)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ecommerce

# JWT secret key (use a long random string)
JWT_SECRET=your_jwt_secret_key

# Session secret (use a long random string)
SESSION_SECRET=your_session_secret

# Node environment
NODE_ENV=production

# Server public URL (Render deployment URL, e.g. https://your-app.onrender.com)
# Used for OAuth callback URLs
SERVER_URL=https://your-backend.onrender.com

# Frontend URL (Vercel deployment URL, e.g. https://your-app.vercel.app)
# Used for CORS and OAuth redirects
CLIENT_URL=https://your-frontend.vercel.app

# Stripe keys (from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Email (SMTP) configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=KHM Electronics <your_email@gmail.com>

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth credentials (from Facebook Developer Console)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Twilio SMS credentials (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your_twilio_phone_number
